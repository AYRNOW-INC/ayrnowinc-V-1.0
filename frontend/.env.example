# AYRNOW Flutter Frontend Environment
# Pass these as dart-define flags when building:
#   flutter run --dart-define=API_BASE_URL=http://localhost:8080/api
#   flutter run --dart-define=STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY

# Backend API base URL
API_BASE_URL=http://localhost:8080/api

# Stripe publishable key (safe for client-side)
# Not required for current Checkout Session flow.
# Required if using Stripe Elements or Apple Pay in-app.
STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# Social Auth (deferred — planned for future native OAuth release)
# Google/Apple sign-in will be added in a future version.
