# AYRNOW Elastic Beanstalk Environment Configuration
# Tuned for t3.micro (1 GB RAM) — minimal cost MVP

option_settings:
  # JVM memory tuned for t3.micro
  aws:elasticbeanstalk:application:environment:
    SERVER_PORT: "5000"
    SPRING_PROFILES_ACTIVE: "aws"
    JAVA_TOOL_OPTIONS: "-Xmx512m -Xms256m -XX:+UseG1GC -XX:MaxMetaspaceSize=128m"

  # Health check
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /api/health
    MatcherHTTPCode: "200"

  # Single instance (no load balancer = saves ~$18/mo)
  aws:elasticbeanstalk:environment:
    EnvironmentType: SingleInstance

  # Instance type
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.micro

  # Enhanced health reporting
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced

  # Stream logs to CloudWatch
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    RetentionInDays: 7
    DeleteOnTerminate: true
