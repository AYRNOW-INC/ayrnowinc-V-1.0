# AYRNOW Backend Environment Variables
# Copy this file to .env and fill in real values

# === PostgreSQL ===
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ayrnow
SPRING_DATASOURCE_USERNAME=ayrnow
SPRING_DATASOURCE_PASSWORD=ayrnow

# === JWT ===
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
STRIPE_SUCCESS_URL=http://localhost:8080/payment/success
STRIPE_CANCEL_URL=http://localhost:8080/payment/cancel

# === Social Auth (deferred — planned for future native OAuth) ===
# Google/Apple sign-in will be implemented as native OAuth in a future release.
# No external auth provider (Authgear, Firebase, etc.) is used.

# === OpenSign (planned) ===
# OPENSIGN_BASE_URL=https://your-opensign-instance.com
# OPENSIGN_API_TOKEN=your-api-token

# === File Storage ===
FILE_UPLOAD_DIR=./uploads

# === Server ===
SERVER_PORT=8080
